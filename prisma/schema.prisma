generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int           @id @default(autoincrement())
  username       String
  email          String        @unique
  hashedPassword String
  createdAt      DateTime      @default(now())
  maps           Map[]
  scores         Leaderboard[]
}

model Map {
  id           Int      @id @default(autoincrement())
  name         String
  thumbnailUrl String
  imageUrl     String
  createdAt    DateTime @default(now())
  users        User[]
}

model Leaderboard {
  id         Int      @id @default(autoincrement())
  userId     Int?
  mapId      Int
  username   String
  startTime  DateTime
  endTime    DateTime
  durationMs Int
  user       User?    @relation(fields: [userId], references: [id])
}
